{
  "name": "pmatrix-backend",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start:api": "node dist/api-server/server.js",
    "start:worker": "node dist/worker.js",
    "dev:api": "ts-node-dev --respawn --transpile-only src/api-server/server.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "ts-node src/lib/db/migrate.ts"
  },
  "dependencies": {
    "@metaapi/metaapi-javascript-sdk": "^13.7.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.8.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "express": "^5.0.0-beta.3",
    "express-rate-limit": "^7.2.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "drizzle-kit": "^0.21.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.2"
  }
}
