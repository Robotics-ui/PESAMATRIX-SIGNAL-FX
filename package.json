{
  "name": "pmatrix-backend",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start:api": "node dist/api-server/server.js",
    "start:worker": "node dist/worker.js",
    "dev:api": "tsx watch src/api-server/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "ts-node src/lib/db/migrate.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.78.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.30.10",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.42",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
